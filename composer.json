{
    "name": "pfaocle/dndbeyond-characters",
    "description": "A small utility to grab D&D characters from the D&D Beyond public API.",
    "type": "project",
    "authors": [
        {
            "name": "Paul Byrne",
            "email": "code@pfaocle.co.uk"
        }
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "guzzlehttp/guzzle": "^7.12"
    },
    "require-dev": {
        "pestphp/pest": "^4.7",
        "phpro/grumphp": "^2.21",
        "squizlabs/php_codesniffer": "^3.7",
        "vimeo/psalm": "^6.16"
    },
    "autoload": {
        "psr-4": {"Pfaocle\\DndBeyondCharacters\\": "src/"}
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpro/grumphp": true
        },
        "sort-packages": true
    }
}
